{
  "name": "youtube-crawl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup-python.mjs",
    "dev:web": "next dev",
    "dev": "next dev",
    "build:web": "next build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "concurrently -k -n WEB,DESKTOP -c auto \"npm:dev:web\" \"wait-on http://127.0.0.1:3000/api/health && cross-env ELECTROBUN_NEXT_URL=http://127.0.0.1:3000 electrobun dev\"",
    "desktop:build": "npm run build:web && cross-env ELECTROBUN_BUNDLE_NEXT=1 electrobun build --env=stable",
    "desktop:run": "electrobun run"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electrobun": "^1.15.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
